{
  "extends": "@voila/typescript-config/tsconfig.build.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*"],
  // The vended items under `src/items/` are templates copied verbatim into a
  // consumer app — they import that app's own modules (`../../content.config`)
  // and packages, so they don't typecheck in place. They ship as source and are
  // read as text by `voila add`; the registry's own code never imports them.
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx", "src/items/**"]
}
