{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": true,
    "composite": true,
    "incremental": true,
    "rewriteRelativeImportExtensions": true,
    "allowJs": false
  }
}
