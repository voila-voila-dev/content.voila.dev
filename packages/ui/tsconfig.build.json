{
  "extends": "@voila/typescript-config/tsconfig.build.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    // shadcn-style primitives use cva + forwardRef + Radix prop forwarding,
    // which routinely defeats inference for isolatedDeclarations. Disable it
    // here only; other packages still enforce it via the build base.
    "isolatedDeclarations": false
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
