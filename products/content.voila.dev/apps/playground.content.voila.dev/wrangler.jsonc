{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "voila-playground",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",

  "d1_databases": [
    {
      "binding": "DATABASE",
      "database_name": "voila-playground",
      "database_id": "23ca52f9-f19e-4d8c-9bfa-82f9bfacaa86",
      "migrations_dir": "migrations"
    }
  ]

  // R2: media storage (lands in M3).
  // "r2_buckets": [
  //   { "binding": "MEDIA", "bucket_name": "voila-playground-media" }
  // ],

  // Queues: background task transport (lands in M5).
  // "queues": {
  //   "producers": [{ "binding": "TASKS", "queue": "voila-playground-tasks" }],
  //   "consumers": [{ "queue": "voila-playground-tasks", "max_batch_size": 10 }]
  // }
}
