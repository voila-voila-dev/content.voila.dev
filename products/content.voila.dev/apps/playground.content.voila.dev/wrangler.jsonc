{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "playground-content-voila-dev",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./src/server-entry.ts",
  "d1_databases": [
    {
      "binding": "DATABASE",
      "database_name": "playground",
      "database_id": "TODO-set-in-cloudflare-dashboard"
    }
  ]
  // "r2_buckets": [ ... ]   // M3
  // "queues": { ... }       // M5
}
