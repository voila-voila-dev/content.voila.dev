{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "voila-playground",
  "compatibility_date": "2025-09-02",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",

  // Production serves at voila-playground.<subdomain>.workers.dev; PR previews
  // (via `wrangler versions upload --preview-alias`) at
  // <alias>-voila-playground.<subdomain>.workers.dev. Set explicitly so the
  // behaviour doesn't depend on Cloudflare's defaults (and to silence the
  // "settings not in your Wrangler file" deploy warnings).
  "workers_dev": true,
  "preview_urls": true,

  "d1_databases": [
    {
      "binding": "DATABASE",
      "database_name": "voila-playground",
      "database_id": "23ca52f9-f19e-4d8c-9bfa-82f9bfacaa86",
      "migrations_dir": "migrations"
    }
  ]

  // R2: media storage (lands in M3).
  // "r2_buckets": [
  //   { "binding": "MEDIA", "bucket_name": "voila-playground-media" }
  // ],

  // Queues: background task transport (lands in M5).
  // "queues": {
  //   "producers": [{ "binding": "TASKS", "queue": "voila-playground-tasks" }],
  //   "consumers": [{ "queue": "voila-playground-tasks", "max_batch_size": 10 }]
  // }
}
