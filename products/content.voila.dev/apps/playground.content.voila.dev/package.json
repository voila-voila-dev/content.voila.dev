{
  "name": "@voila/playground.content.voila.dev",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 8787",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "bun run build && wrangler deploy",
    "db:schema": "voila schema generate",
    "db:generate": "voila migrate generate",
    "db:apply": "voila migrate apply --target d1-local --binding DATABASE",
    "db:apply:remote": "voila migrate apply --target d1-remote --binding DATABASE",
    "db:seed": "bun ./scripts/seed.ts"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.10.5",
    "@tanstack/react-query": "^5.100.13",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.10",
    "@tanstack/router-plugin": "^1.132.0",
    "@voila/content": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.7.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "^4",
    "@voila/content-cli": "workspace:*",
    "@voila/typescript-config": "workspace:*",
    "vite": "catalog:",
    "wrangler": "^4.70.0"
  }
}
