{
  "extends": "@voila/typescript-config/tsconfig.build.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": ".",
    // `@voila/content` resolves to its TS source in-repo, whose public index
    // re-exports the admin widgets (→ `@voila/ui`, DOM APIs). Type-checking
    // that transitively-pulled source needs the DOM lib, even though this
    // package ships no DOM code itself. Mirrors @voila/content + @voila/ui.
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
