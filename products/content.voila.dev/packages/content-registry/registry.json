{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "voila",
  "homepage": "https://content.voila.dev",
  "items": [
    {
      "name": "server/mount",
      "type": "registry:file",
      "description": "Thin ~3-line mount file that wires the engine handler to the consumer's content.config.",
      "files": [
        {
          "path": "src/items/admin-shell/app/server/voila.ts",
          "target": "app/server/voila.ts",
          "type": "registry:file"
        }
      ],
      "deps": ["@voila/content"],
      "registryDeps": []
    },
    {
      "name": "route/admin-splat",
      "type": "registry:file",
      "description": "TanStack splat route at /admin/* that mounts the vended admin shell.",
      "files": [
        {
          "path": "src/items/admin-shell/app/routes/admin/$.tsx",
          "target": "app/routes/admin/$.tsx",
          "type": "registry:file"
        }
      ],
      "deps": ["@tanstack/react-router", "@tanstack/react-start"],
      "registryDeps": []
    },
    {
      "name": "admin-shell",
      "type": "registry:component",
      "description": "Empty admin shell vended into the consumer's app — branding-aware Hello shell plus the thin engine mount.",
      "files": [
        {
          "path": "src/items/admin-shell/app/routes/admin/$.tsx",
          "target": "app/routes/admin/$.tsx",
          "type": "registry:file"
        },
        {
          "path": "src/items/admin-shell/app/server/voila.ts",
          "target": "app/server/voila.ts",
          "type": "registry:file"
        }
      ],
      "deps": [
        "@tanstack/react-router",
        "@tanstack/react-start",
        "@voila/content",
        "@voila/content-schema"
      ],
      "registryDeps": ["route/admin-splat", "server/mount"]
    }
  ]
}
