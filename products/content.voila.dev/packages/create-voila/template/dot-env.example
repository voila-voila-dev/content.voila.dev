# Copy to .env and fill in. `create-voila` writes a real .env with a generated
# secret for you; this committed example documents the keys for teammates.

# Secret that signs auth sessions, magic-link tokens, and the CSRF token.
# Generate one with: openssl rand -base64 32
VOILA_AUTH_SECRET=

# The app's own URL. Used for magic-link verify links and to decide whether
# auth cookies are `Secure` (https → yes). Set this to your deployed origin.
VOILA_BASE_URL=http://localhost:3000

# Magic links print to the dev server's terminal by default. To send real
# email, set a Resend API key and a verified from-address:
# RESEND_API_KEY=re_...
# VOILA_AUTH_FROM="Acme <admin@acme.dev>"
