# Copy to .env and fill in. The secret signs auth sessions, magic-link tokens,
# and the CSRF token. Generate one with: openssl rand -base64 32
VOILA_AUTH_SECRET=

VOILA_BASE_URL=http://localhost:3000

# Magic links print to the dev server terminal by default. To send real email:
# RESEND_API_KEY=re_...
# VOILA_AUTH_FROM="Demo <admin@demo.dev>"
