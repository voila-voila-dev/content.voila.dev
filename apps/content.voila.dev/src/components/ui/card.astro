---
import { cn } from "#/lib/utils";

interface Props {
  as?: string;
  class?: string;
  [key: string]: unknown;
}

const { as: Tag = "div", class: className, ...rest } = Astro.props;
---

<Tag
  class={cn(
    "rounded-xl border border-border bg-card text-card-foreground shadow-sm",
    className,
  )}
  {...rest}
>
  <slot />
</Tag>
