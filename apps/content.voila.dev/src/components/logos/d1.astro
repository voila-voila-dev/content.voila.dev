---
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className, ...rest } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 40 44"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Cloudflare D1"
  {...rest}
>
  <g fill="#F6821F">
    <ellipse cx="20" cy="11" rx="13" ry="5.5"></ellipse>
    <path d="M7 11v22c0 3 5.8 5.5 13 5.5s13-2.5 13-5.5V11c0 3-5.8 5.5-13 5.5S7 14 7 11Z"></path>
  </g>
  <g fill="none" stroke="#ffffff" stroke-width="2" opacity="0.4">
    <path d="M7 22c0 3 5.8 5.5 13 5.5S33 25 33 22"></path>
  </g>
</svg>
