---
interface Props {
  class?: string;
  [key: string]: unknown;
}

const { class: className, ...rest } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 64 40"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Cloudflare"
  {...rest}
>
  <g fill="#FBAD41">
    <circle cx="45" cy="25" r="8"></circle>
    <circle cx="53" cy="27" r="6"></circle>
    <rect x="41" y="25" width="14" height="8" rx="4"></rect>
  </g>
  <g fill="#F6821F">
    <circle cx="18" cy="24" r="8"></circle>
    <circle cx="31" cy="16" r="11"></circle>
    <circle cx="43" cy="24" r="8"></circle>
    <rect x="18" y="22" width="25" height="11" rx="5.5"></rect>
  </g>
</svg>
