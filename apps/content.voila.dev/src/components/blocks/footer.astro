---
import Container from "#/components/ui/container.astro";
import Icon from "#/components/ui/icon.astro";

const year = 2026;

const columns = [
  {
    title: "Product",
    links: [
      { label: "Features", href: "#features" },
      { label: "Open source", href: "#open-source" },
      { label: "Changelog", href: "#" },
      { label: "Roadmap", href: "#" },
    ],
  },
  {
    title: "Developers",
    links: [
      { label: "Documentation", href: "#" },
      { label: "Quickstart", href: "#cta" },
      { label: "API reference", href: "#" },
      { label: "Examples", href: "#" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "#" },
      { label: "Blog", href: "#" },
      { label: "Contact", href: "#" },
      { label: "Privacy", href: "#" },
    ],
  },
];

const socials = [
  { name: "GitHub", icon: "github", href: "https://github.com/voila-voila-dev" },
  { name: "X", icon: "x-social", href: "https://x.com" },
];
---

<footer class="border-t border-border/60">
  <Container class="py-16">
    <div class="grid gap-12 lg:grid-cols-[1.5fr_repeat(3,1fr)]">
      <div>
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight">
          <span class="grid size-7 place-items-center rounded-md bg-primary text-primary-foreground">
            <Icon name="sparkles" class="size-4" />
          </span>
          <span>content<span class="text-muted-foreground">.voila.dev</span></span>
        </a>
        <p class="mt-4 max-w-xs text-sm text-muted-foreground">
          The config-driven, type-safe content framework for the edge.
        </p>
      </div>

      {
        columns.map((col) => (
          <div>
            <h3 class="text-sm font-semibold">{col.title}</h3>
            <ul class="mt-4 space-y-3">
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                  >
                    {l.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-12 flex flex-col items-center justify-between gap-4 border-t border-border/60 pt-8 sm:flex-row"
    >
      <p class="text-sm text-muted-foreground">© {year} voila.dev — MIT licensed.</p>
      <div class="flex items-center gap-1">
        {
          socials.map((s) => (
            <a
              href={s.href}
              aria-label={s.name}
              class="grid size-9 place-items-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
            >
              <Icon name={s.icon} class="size-4" />
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</footer>
