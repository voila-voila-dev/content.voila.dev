{
  "name": "content.voila.dev",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "products/*/apps/*",
      "products/*/packages/*",
      "products/*/examples/*"
    ],
    "catalog": {
      "react": "19.0.0",
      "react-dom": "19.0.0",
      "@types/react": "19.0.1",
      "@types/react-dom": "19.0.1"
    }
  },
  "scripts": {
    "prepare": "lefthook install",
    "lint": "biome lint --write",
